		"faq": {
			"eyebrow": "FAQ",
			"title": "Frequently asked questions",
			"items": [
				{
					"q": "What level can I start at?",
					"a": "Any. The platform suits both complete beginners (A1) and those who already read fluently (C1–C2). Texts are organised by level, so you can begin with the simplest."
				},
				{
					"q": "How do «Decks» differ from regular spaced repetition?",
					"a": "They're two independent systems. SM-2 is the classic algorithm with intervals and 0–5 ratings. Decks is a proprietary system: words are distributed across decks (NEW → OLD → NUMBERED), numbered decks rotate every day. Use either — or both."
				},
				{
					"q": "Can I cancel my subscription?",
					"a": "Yes, anytime in one click. Access to paid features stays until the end of the paid period — then the account switches to the free plan automatically without losing data."
				},
				{
					"q": "What happens to my vocabulary if I stop using the service?",
					"a": "Your personal vocabulary, text progress and review history are preserved as long as the account exists. They can be exported anytime."
				},
				{
					"q": "Which languages are supported?",
					"a": "Currently — Chechen (CHE) with translation to Russian (RU). The architecture supports adding other languages; new directions will be added based on community requests."
				},
				{
					"q": "Is there a mobile app?",
					"a": "The web version is adapted for phones and tablets — opens in a browser and works like a native app. Dedicated iOS/Android apps are planned."
				}
			]
		},
